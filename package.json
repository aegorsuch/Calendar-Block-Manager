{
  "name": "calendar-block-manager",
  "version": "1.0.0",
  "private": true,
  "description": "Local workflow scripts for Google Apps Script and Git sync",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "coverage": "nyc npm test",
    "lint": "eslint src tests",
    "format": "prettier --write src tests",
    "check:policy": "node scripts/check-policy.js",
    "check:full": "npm run check:policy && npm test",
    "setup:hooks": "git config core.hooksPath .githooks",
    "gas:status": "clasp status",
    "gas:pull": "clasp pull",
    "gas:push": "clasp push",
    "gas:open": "clasp open-script",
    "deploy:all": "node scripts/deploy-all.js",
    "git:status": "git status",
    "git:sync": "git add . && git commit -m \"chore: sync local changes\" && git push"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "nyc": "^18.0.0",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3"
  }
}
